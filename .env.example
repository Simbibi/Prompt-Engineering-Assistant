# .env.example
# Copy this file to `.env` and fill in real values (do NOT commit `.env`).

# Secrets (either API_KEY or LLM_VENDER_SECRET is used by the app)
API_KEY=your_api_key_here
LLM_VENDER_SECRET=your_llm_vender_secret_here

# LLM / Provider
LLM_BASE_URL=https://api.polza.ai/v1
LLM_MODEL=google/gemini-2.0-flash-001

# Database (example: sqlite local or a full postgres URL)
DATABASE_URL=sqlite:///chroma_db/chroma.sqlite3
DB_SCHEMA=public
CHROMA_DB_DIR=chroma_db
CHROMA_DB_PATH=chroma_db/chroma.sqlite3

# App
PORT=8000
LOG_LEVEL=INFO

# Optional vector DB / external services (leave empty if unused)
PINECONE_API_KEY=
PINECONE_ENV=
PINECONE_INDEX_NAME=

# Embedding / model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Usage:
# 1) Copy to .env: `cp .env.example .env`
# 2) Edit `.env` and fill real secret values before running the app.
